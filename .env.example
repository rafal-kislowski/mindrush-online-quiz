# Core profile
SPRING_PROFILES_ACTIVE=prod

# Database
MYSQL_DATABASE=mindrush
MYSQL_USER=mindrush
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PORT=3306
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/mindrush?serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=mindrush
SPRING_DATASOURCE_PASSWORD=change-me-db-password

# Security
JWT_SECRET=change-me-very-long-random-secret
AUTH_COOKIE_SECURE=true
APP_CORS_ALLOWED_ORIGINS=https://demo.your-domain.com
FRONTEND_PORT=80

# Frontend URL used in emails
APP_FRONTEND_BASE_URL=https://demo.your-domain.com

# Flyway
APP_FLYWAY_ENABLED=true
APP_FLYWAY_BASELINE_ON_MIGRATE=true

# Runtime JVM flags
JAVA_OPTS=-Xms256m -Xmx768m

# Optional bootstrap admin (recommended only for first deployment, then remove)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Mail (set APP_MAIL_ENABLED=true only when SMTP is configured)
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@your-domain.com
APP_MAIL_SUPPORT=support@your-domain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true

# AI generation (optional)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tools profile (phpMyAdmin)
PHPMYADMIN_PORT=8081
