# Public demo profile
SPRING_PROFILES_ACTIVE=demo

# Database
MYSQL_DATABASE=mindrush_demo
MYSQL_USER=mindrush
MYSQL_PASSWORD=change-me-demo-db-password
MYSQL_ROOT_PASSWORD=change-me-demo-root-password
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/mindrush_demo?serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=mindrush
SPRING_DATASOURCE_PASSWORD=change-me-demo-db-password

# Security
JWT_SECRET=change-me-demo-very-long-random-secret
AUTH_COOKIE_SECURE=true
APP_CORS_ALLOWED_ORIGINS=https://demo-mindrush.rafalkislowski.pl
FRONTEND_PORT=8084
PROXY_FRONTEND_HOSTNAME=demo-mindrush-frontend

# Frontend URL used in demo banner / links
APP_FRONTEND_BASE_URL=https://demo-mindrush.rafalkislowski.pl

# Flyway
APP_FLYWAY_ENABLED=true
APP_FLYWAY_BASELINE_ON_MIGRATE=true

# Runtime JVM flags
JAVA_OPTS=-Xms256m -Xmx768m

# Demo disables bootstrap admin, mail and AI integrations
ADMIN_EMAIL=
ADMIN_PASSWORD=
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@mindrush.local
APP_MAIL_SUPPORT=support@mindrush.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional demo tuning
APP_DEMO_RESET_ON_STARTUP=true
APP_DEMO_RESET_SCHEDULED=true
APP_DEMO_SIMULATION_ENABLED=true
APP_DEMO_OPEN_AUTH_LOBBIES=6
APP_DEMO_OPEN_GUEST_LOBBIES=4
APP_DEMO_IN_GAME_LOBBIES=2
APP_DEMO_AUTH_POOL_SIZE=4
APP_DEMO_GUEST_POOL_SIZE=2

# Optional tools profile (phpMyAdmin)
PHPMYADMIN_PORT=8082
